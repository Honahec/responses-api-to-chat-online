OPENAI_API_KEY=<your-openai-api-key>
# Optional: override the OpenAI-compatible API base URL.
# Include the API version path when your provider requires it, e.g. https://api.openai.com/v1
OPENAI_BASE_URL=
DATABASE_URL="postgres://app:app_password@localhost:5432/responses_app"
GOOGLE_CLIENT_ID=<oauth-client-app-id>
GOOGLE_CLIENT_SECRET=<oauth-client-secret>
GOOGLE_REDIRECT_URI="http://localhost:3000/api/google/callback"
