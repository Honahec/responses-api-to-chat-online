# Used to encrypt user-owned provider API keys and connector/tool secrets.
# Generate a strong value, for example: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=
POSTGRES_DB=responses_app
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
# Used by docker-compose to repair/reconcile an existing Postgres volume before migrations.
# For a fresh volume, keep these equal to POSTGRES_USER/POSTGRES_PASSWORD.
# If you previously initialized the volume with different credentials, set the old superuser here.
POSTGRES_BOOTSTRAP_USER=app
POSTGRES_BOOTSTRAP_PASSWORD=change-me
POSTGRES_BOOTSTRAP_DB=postgres
APP_PORT=3000
# Local host access, e.g. running migrations outside Docker.
DATABASE_URL="postgres://app:change-me@localhost:5432/responses_app"
# Container-to-container access used by docker-compose services.
APP_DATABASE_URL="postgres://app:change-me@postgres:5432/responses_app"
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI="http://localhost:3000/api/auth/callback"
OIDC_GROUPS_CLAIM=groups
OIDC_ADMIN_GROUP=superadmin
OIDC_USER_GROUP=chat_user
OIDC_SCOPES="openid email profile groups"
GOOGLE_CLIENT_ID=<oauth-client-app-id>
GOOGLE_CLIENT_SECRET=<oauth-client-secret>
GOOGLE_REDIRECT_URI="http://localhost:3000/api/google/callback"
